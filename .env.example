# ---------------------------------------------------------------------------
# HotelTrack tracking snippet
# ---------------------------------------------------------------------------
# These two PUBLIC env vars drive the tracking snippet injected in app/layout.tsx.
# The snippet only renders when NEXT_PUBLIC_HOTELTRACK_SITE_ID is set, so the
# site runs fine locally without them.
#
# Copy this file to `.env.local` for local development, and set the same vars
# in the Vercel project settings (Production + Preview) for deployment.

NEXT_PUBLIC_HOTELTRACK_APP_URL=https://app.hoteltrack.example
NEXT_PUBLIC_HOTELTRACK_SITE_ID=

# ---------------------------------------------------------------------------
# Database (Prisma)
# ---------------------------------------------------------------------------
# PostgreSQL (Vercel Postgres / Neon). DATABASE_URL is the pooled connection
# used at runtime; DATABASE_URL_UNPOOLED is the direct connection used by the
# Prisma CLI for migrations. The Vercel Postgres integration sets both for you;
# for local dev, copy them from Vercel → Storage → your DB → ".env.local" tab.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"

# ---------------------------------------------------------------------------
# SMTP — booking invoice email (optional)
# ---------------------------------------------------------------------------
# All five must be set to send invoice emails. If any is missing, sending is
# skipped (logged) and the booking still confirms; the invoice stays viewable
# at /invoice/<reference>.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Neelakurunji Bookings <bookings@example.com>"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5) — Google Sign-In
# ---------------------------------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# IDs. Authorized redirect URI must be:
#   <AUTH_URL>/api/auth/callback/google
#   e.g. http://localhost:3000/api/auth/callback/google  (local)
#        https://your-app.vercel.app/api/auth/callback/google  (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Secret used to encrypt tokens/cookies. Generate with: openssl rand -hex 32
AUTH_SECRET=
# Base URL of the app. Local: http://localhost:3000
# On Vercel this is auto-detected, but set it for clarity / preview URLs.
AUTH_URL=http://localhost:3000
